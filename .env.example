# ================================
# AI Studio - Environment Configuration
# ================================

# ================================
# Provider Configuration (up to 10 providers)
# ================================

# Provider 1: Standard OpenAI
PROVIDER_1_NAME=OpenAI DALL·E
PROVIDER_1_TYPE=openai
PROVIDER_1_BASE_URL=https://api.openai.com/v1
PROVIDER_1_API_KEY=sk-xxxx
PROVIDER_1_MODELS=dall-e-3,dall-e-2,gpt-image-1

# Provider 2: OpenAI Compatible (Reverse Proxy)
# Uses Chat Completions endpoint, extracts image URLs from markdown
#PROVIDER_2_NAME=Reverse Chat API
#PROVIDER_2_TYPE=openai-compatible
#PROVIDER_2_BASE_URL=https://your-reverse-proxy.com/v1
#PROVIDER_2_API_KEY=sk-xxxx
#PROVIDER_2_MODELS=gpt-4o,gpt-4o-mini

# Provider 3: Google Gemini
#PROVIDER_3_NAME=Google Gemini
#PROVIDER_3_TYPE=gemini
#PROVIDER_3_BASE_URL=https://generativelanguage.googleapis.com/v1beta
#PROVIDER_3_API_KEY=AIzaSyXXXX
#PROVIDER_3_MODELS=gemini-2.0-flash-exp

# Provider 4: Grok2API (Dedicated - image, edit, video)
#PROVIDER_4_NAME=Grok2API
#PROVIDER_4_TYPE=grok2api
#PROVIDER_4_BASE_URL=https://your-grok2api.com/v1
#PROVIDER_4_API_KEY=sk-xxxx
#PROVIDER_4_IMAGE_MODELS=grok-imagine-1.0,grok-imagine-1.0-fast
#PROVIDER_4_IMAGE_EDIT_MODELS=grok-imagine-1.0-edit
#PROVIDER_4_VIDEO_MODELS=grok-imagine-1.0-video

# ================================
# Server Configuration
# ================================

# Server Port (default: 8787)
PORT=8787

# ================================
# Lsky Pro Image Hosting (Optional)
# ================================

# Lsky Pro API URL
LSKY_URL=

# Lsky Pro API Token
LSKY_TOKEN=

# Lsky Pro Storage Strategy ID (default: 1)
LSKY_STRATEGY_ID=1

# ================================
# Authentication (Optional)
# ================================

AUTH_PASSWORD=your_secure_password_here

# ================================
# Advanced Configuration
# ================================

MAX_REQUEST_SIZE=50
REQUEST_TIMEOUT=120000
MAX_BULK_REQUESTS=5

# ================================
# Security Configuration
# ================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=500

# ================================
# Logging Configuration
# ================================

LOG_LEVEL=info
LOG_REQUESTS=true
